# SIGNA web — environment variables.
#
# REQUIRED for the app to boot at all:

# WalletConnect / Reown — get a free project id at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Supabase — project `sufikdvzvwgiggzyeuge`
NEXT_PUBLIC_SUPABASE_URL=https://sufikdvzvwgiggzyeuge.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional but recommended for server routes (bypasses RLS for signature-verified writes)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# REQUIRED for AI features (digest cron, /api/agents/[address]/respond):
GROQ_API_KEY=gsk_your_groq_key            # https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile         # optional override

# REQUIRED for custodial signing (agents/respond signs replies; vault for /trade,
# /me/bankr-key). Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_RUNTIME_MASTER_KEY=                  # 32 raw bytes, hex (64 chars, with or without 0x prefix)

# Bot publishers — wallet-signed feed posts authored by these bots.
# Visit /admin/generate-bot-keys once to mint these.
MIROSHARK_BOT_KEY=                          # 0x-prefixed 64-hex-char private key
GITLAWB_BOT_KEY=
BANKR_BOT_KEY=

# MiroShark integration — leave blank if you don't have a sandbox URL yet;
# the /respond swarm intent will fall back gracefully.
MIROSHARK_BASE_URL=
MIROSHARK_API_KEY=
MIROSHARK_WEBHOOK_SECRET=

# Cron — protects /api/cron/* from random callers.
CRON_SECRET=
