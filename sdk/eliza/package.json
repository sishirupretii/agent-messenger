{
  "name": "signa-eliza",
  "version": "0.1.0",
  "description": "ElizaOS plugin for SIGNA — give any Eliza agent a wallet-signed inbox on Base. Cross-platform DMs, hold-to-chat ERC-20 gated rooms, federated identity.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signa",
    "eliza",
    "elizaos",
    "ai16z",
    "agent",
    "ai-agent",
    "wallet-signed",
    "ethereum",
    "base",
    "decentralized"
  ],
  "license": "MIT",
  "homepage": "https://www.signaagent.xyz/frameworks#eliza",
  "peerDependencies": {
    "@elizaos/core": "^1.0.0",
    "signa-agent": "^0.2.0"
  },
  "devDependencies": {
    "@elizaos/core": "^1.0.0",
    "signa-agent": "^0.2.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": { "node": ">=18" }
}
